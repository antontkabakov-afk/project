# Public ports exposed by docker compose
WEB_PORT=8080
API_PORT=8081

# PostgreSQL container settings
POSTGRES_DB=crypto_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
IS_DUMMY_INFO=falce

# API runtime settings
JWT_ACCESS_SECRET=replace-with-at-least-32-bytes-random-secret
CLIENT_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:4173

# Cookies
# Set AUTH_COOKIE_SECURE=true when the app is served over HTTPS.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_DOMAIN=

# External APIs
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3/
COINGECKO_DEMO_API_KEY=
COINGECKO_SUPPORTED_COINS=bitcoin,ethereum,solana,ripple,cardano,dogecoin,tron,avalanche-2,polkadot,chainlink

MORALIS_BASE_URL=https://deep-index.moralis.io/api/v2.2/
MORALIS_API_KEY=
MORALIS_DEFAULT_CHAIN=eth
MORALIS_SUPPORTED_CHAINS=eth,polygon,base,arbitrum,optimism,bsc,avalanche

# Background snapshot intervals
CRYPTO_PRICE_SNAPSHOT_INTERVAL_MINUTES=15
CRYPTO_PRICE_BACKFILL_DAYS=30
PORTFOLIO_SNAPSHOT_INTERVAL_MINUTES=60
